{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "default_agent": "polish",
  "instructions": [
    "PLAN/README.md",
    "PLAN/01-code-cleanup.md",
    "PLAN/02-documentation.md",
    "PLAN/03-optimization.md",
    "PLAN/04-testing.md"
  ],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "write": "allow",
    "bash": "ask"
  },
  "share": "manual"
}
